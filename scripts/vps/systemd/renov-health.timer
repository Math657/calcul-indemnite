[Unit]
Description=Daily MaRénovAide health check

[Timer]
# Daily at 18:00 UTC — well after the weekly publish (Fri 02:00) and the
# daily rebuild (13:30) windows. Catches stuck/failed runs the same day.
OnCalendar=*-*-* 18:00:00 UTC
RandomizedDelaySec=300
Persistent=true
Unit=renov-health.service

[Install]
WantedBy=timers.target
