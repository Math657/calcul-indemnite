[Unit]
Description=Calcul Indemnité scrape pipeline health check
After=network-online.target postgresql.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/indemnite/pipeline
EnvironmentFile=/home/ubuntu/indemnite/.env.local
ExecStart=/home/ubuntu/indemnite/pipeline/.venv/bin/python -m pipeline.cli health
StandardOutput=journal
StandardError=journal
# Non-zero exit means issues; that's expected behavior, not service failure.
SuccessExitStatus=0 1
