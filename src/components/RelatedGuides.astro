---
/**
 * "Dossiers liés" widget — shown at the bottom of dossier pages and hub
 * landings. Prefers dossiers in the same hub, falls back to any published
 * one. Excludes the current dossier, drafts, and future-dated (drip) entries.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import GuideCard from './GuideCard.astro';
import { HUBS } from '../data/hubs';

interface Props {
  /** Slug of the current dossier — excluded from the list. Leave undefined on hub landings. */
  excludeSlug?: string;
  /** Preferred hub to filter by (a key of HUBS). Falls back to all published dossiers. */
  preferHub?: keyof typeof HUBS;
  /** Max number to render. Default 3. */
  limit?: number;
  /** Heading shown above the list. Default "Dossiers liés". */
  heading?: string;
}

const { excludeSlug, preferHub, limit = 3, heading = 'Dossiers liés' } = Astro.props;

const todayISO = new Date().toISOString().slice(0, 10);
const all = await getCollection('dossiers', (entry: CollectionEntry<'dossiers'>) => {
  if (entry.data.draft) return false;
  if (entry.data.datePublished > todayISO) return false;
  if (excludeSlug && entry.slug === excludeSlug) return false;
  return true;
});

const sortByDate = (a: CollectionEntry<'dossiers'>, b: CollectionEntry<'dossiers'>) =>
  b.data.datePublished.localeCompare(a.data.datePublished);

const sameHub = preferHub ? all.filter((a: CollectionEntry<'dossiers'>) => a.data.hub === preferHub) : [];
const otherHubs = all.filter((a: CollectionEntry<'dossiers'>) => !sameHub.includes(a));
sameHub.sort(sortByDate);
otherHubs.sort(sortByDate);

const related = [...sameHub, ...otherHubs].slice(0, limit);
---
{related.length > 0 && (
  <aside class="mt-12">
    <h2 class="text-2xl font-bold text-slate-900">{heading}</h2>
    <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((a: CollectionEntry<'dossiers'>) => (
        <GuideCard
          title={a.data.title}
          description={a.data.description}
          slug={a.slug}
          datePublished={a.data.datePublished}
          hub={a.data.hub}
        />
      ))}
    </div>
  </aside>
)}
