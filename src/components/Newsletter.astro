---
import { SITE } from '../data/site';

interface Props {
  /** Visual variant. `inline` for in-page placement, `footer` for compact footer column. */
  variant?: 'inline' | 'footer';
  title?: string;
  body?: string;
}

const { variant = 'inline', title, body } = Astro.props;

const username = SITE.newsletter?.username;
const isWired = Boolean(username);
const action = isWired ? `https://buttondown.com/api/emails/embed-subscribe/${username}` : null;

const defaultTitle = 'Restez informé';
const defaultBody = 'Recevez un avis quand un barème change ou qu’un nouveau simulateur est publié. Pas de spam, désinscription en un clic.';
---
{variant === 'inline' ? (
  <aside class="rounded-xl border border-indigo-200 bg-indigo-50 p-5" aria-label="Inscription à la newsletter">
    <h3 class="text-lg font-semibold text-indigo-900">{title ?? defaultTitle}</h3>
    <p class="mt-2 text-sm leading-relaxed text-slate-700">{body ?? defaultBody}</p>
    {isWired ? (
      <form action={action!} method="post" target="popupwindow" class="mt-4 flex flex-col gap-2 sm:flex-row">
        <label for="newsletter-email-inline" class="sr-only">Email</label>
        <input
          id="newsletter-email-inline"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="votre@email.fr"
          class="flex-1 rounded-md border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
        />
        <input type="hidden" value="1" name="embed" />
        <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700">
          S’inscrire
        </button>
      </form>
    ) : (
      <p class="mt-3 text-xs italic text-slate-500">Bientôt : le canal d’avis est en préparation.</p>
    )}
    <p class="mt-3 text-xs text-slate-500">Votre email est traité conformément à notre <a href="/politique-de-confidentialite" class="hover:underline">Politique de confidentialité</a>. RGPD.</p>
  </aside>
) : (
  <div>
    <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Newsletter</h3>
    <p class="mt-3 text-sm text-slate-700">Avis de nouveaux simulateurs et changements de barème. Pas de spam.</p>
    {isWired ? (
      <form action={action!} method="post" target="popupwindow" class="mt-3 flex gap-2">
        <label for="newsletter-email-footer" class="sr-only">Email</label>
        <input
          id="newsletter-email-footer"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="votre@email.fr"
          class="flex-1 rounded-md border border-slate-300 bg-white px-2 py-1.5 text-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"
        />
        <input type="hidden" value="1" name="embed" />
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white transition hover:bg-indigo-700" aria-label="S’inscrire à la newsletter">OK</button>
      </form>
    ) : (
      <p class="mt-2 text-xs italic text-slate-500">Bientôt</p>
    )}
  </div>
)}
