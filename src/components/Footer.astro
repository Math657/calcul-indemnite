---
import Newsletter from './Newsletter.astro';
import { HUBS } from '../data/hubs';
import { SITE } from '../data/site';

const hubs = Object.values(HUBS);
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 pt-12 pb-6 sm:px-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 sm:p-8">
      <Newsletter variant="inline" />
    </div>
  </div>

  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-6 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-1">
      <a href="/" class="flex items-center gap-2 font-bold text-slate-900">
        <span class="inline-flex size-8 items-center justify-center rounded-lg bg-indigo-600 text-base font-black text-white">C</span>
        <span class="text-lg tracking-tight">{SITE.name}</span>
      </a>
      <p class="mt-3 text-sm text-slate-600">{SITE.tagline}.</p>
      <p class="mt-2 text-xs text-slate-500">Contenu informatif. Ne remplace pas l’avis d’un avocat ou d’un conseiller juridique.</p>
    </div>

    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Catégories</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {hubs.map((h) => (
          <li><a href={h.path} class="text-slate-700 hover:text-indigo-700 hover:underline">{h.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Sources officielles</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="https://www.legifrance.gouv.fr/codes/texte_lc/LEGITEXT000006072050" rel="external" class="text-slate-700 hover:text-indigo-700 hover:underline">Code du travail — Légifrance</a></li>
        <li><a href="https://www.service-public.fr/particuliers/vosdroits/N19806" rel="external" class="text-slate-700 hover:text-indigo-700 hover:underline">service-public.fr — Travail</a></li>
        <li><a href="https://code.travail.gouv.fr" rel="external" class="text-slate-700 hover:text-indigo-700 hover:underline">Code du travail numérique</a></li>
        <li><a href="https://www.courdecassation.fr" rel="external" class="text-slate-700 hover:text-indigo-700 hover:underline">Cour de cassation</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">Institutionnel</h3>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/a-propos" class="text-slate-700 hover:text-indigo-700 hover:underline">À propos</a></li>
        <li><a href="/contact" class="text-slate-700 hover:text-indigo-700 hover:underline">Contact</a></li>
        <li><a href="/mentions-legales" class="text-slate-700 hover:text-indigo-700 hover:underline">Mentions légales</a></li>
        <li><a href="/politique-de-confidentialite" class="text-slate-700 hover:text-indigo-700 hover:underline">Politique de confidentialité</a></li>
        <li><a href="/cgu" class="text-slate-700 hover:text-indigo-700 hover:underline">CGU</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-4 py-5 text-xs text-slate-500 sm:px-6 md:flex-row md:items-center">
      <p>© {year} {SITE.name}. Tous droits réservés.</p>
      <p>Sources Légifrance et service-public.fr, mises à jour régulières.</p>
    </div>
  </div>
</footer>
