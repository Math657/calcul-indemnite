---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';

const seo = {
  title: `Contact — Erreur, suggestion, presse, RGPD | ${SITE.name}`,
  description: 'Signaler une erreur de calcul, proposer une amélioration, parler d’un partenariat ou exercer vos droits RGPD : voici comment nous joindre.',
  path: '/contact',
};

const breadcrumbItems = [
  { name: 'Accueil', path: '/' },
  { name: 'Contact', path: '/contact' },
];

interface ContactRow {
  category: string;
  description: string;
  email: string;
  subject: string;
}

const rows: ContactRow[] = [
  {
    category: 'Erreur de calcul ou de source',
    description:
      'Vous pensez qu’un barème ou un coefficient affiché est incorrect. Précisez la page, la valeur lue, et la valeur que vous attendiez avec sa source.',
    email: SITE.contactEmail,
    subject: 'Erreur de calcul ou de source',
  },
  {
    category: 'Suggestion d’amélioration',
    description: 'Une fonctionnalité manquante, un cas non couvert, un guide à écrire.',
    email: SITE.contactEmail,
    subject: 'Suggestion',
  },
  {
    category: 'Partenariat / affiliation',
    description: 'Services juridiques, médias.',
    email: SITE.contactEmail,
    subject: 'Partenariat',
  },
  {
    category: 'Presse',
    description: 'Demandes d’interview, citations, accès aux données.',
    email: SITE.contactEmail,
    subject: 'Presse',
  },
  {
    category: 'RGPD / protection des données',
    description: 'Exercice des droits (accès, rectification, effacement, opposition, portabilité).',
    email: SITE.privacyEmail,
    subject: 'Demande RGPD',
  },
];
---
<Base {seo}>
  <Container as="main" size="md" class="py-12 sm:py-16">
    <Breadcrumbs items={breadcrumbItems} />

    <h1 class="mt-6 text-4xl font-extrabold text-slate-900 sm:text-5xl">Contact</h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-700">
      Pour le moment, le contact se fait par email — pas de formulaire en ligne. Choisissez la catégorie ci-dessous et votre client mail s’ouvrira avec l’objet pré-rempli.
    </p>

    <ul class="mt-10 space-y-5">
      {rows.map((r) => (
        <li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
          <h3 class="text-base font-semibold text-slate-900">{r.category}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{r.description}</p>
          <a
            href={`mailto:${r.email}?subject=${encodeURIComponent(r.subject)}`}
            class="mt-3 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700"
          >
            Écrire à {r.email} →
          </a>
        </li>
      ))}
    </ul>

    <p class="mt-10 rounded-md border-l-4 border-amber-400 bg-amber-50 p-4 text-sm text-slate-700">
      Question personnelle sur votre situation : {SITE.name} ne donne pas de conseil juridique personnalisé. Consultez un avocat en droit du travail ou un conseiller juridique.
    </p>
  </Container>
</Base>
