---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import Methodology from '../components/Methodology.astro';
import { HUBS } from '../data/hubs';
import { SITE } from '../data/site';

const seo = {
  title: `${SITE.name} — calcul d’indemnité de licenciement 2026`,
  description: SITE.description,
  path: '/',
};

const hubs = Object.values(HUBS);
---
<Base {seo}>
  <Hero
    eyebrow="Code du travail 2026"
    title="Calculez votre indemnité de licenciement en 2 minutes"
    subtitle="Indemnité légale, barème prud’hommes (barème Macron) et rupture conventionnelle, avec les règles 2026. Sourcé, daté, gratuit, sans inscription. Le calcul s’exécute dans votre navigateur."
  >
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/calcul-indemnite-licenciement" class="rounded-lg bg-white px-5 py-3 font-semibold text-indigo-700 shadow-sm transition hover:bg-indigo-50">
        Lancer le calcul →
      </a>
      <a href="/bareme-macron" class="rounded-lg border border-white/40 px-5 py-3 font-semibold text-white transition hover:bg-white/10">
        Voir le barème prud’hommes
      </a>
    </div>
  </Hero>

  <Container as="section" size="lg" class="py-12 sm:py-16">
    <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">Par où commencer</h2>
    <p class="mt-3 max-w-2xl text-slate-600">
      Quatre entrées selon votre situation : un montant chiffré, le détail du barème prud’hommes, la rupture conventionnelle, ou nos dossiers pratiques.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {hubs.map((h) => (
        <a
          href={h.path}
          class="group flex flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-indigo-400 hover:shadow-md"
        >
          <h3 class="text-lg font-semibold text-slate-900 group-hover:text-indigo-700">{h.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{h.description}</p>
          <span class="mt-4 text-sm font-medium text-indigo-700">Découvrir →</span>
        </a>
      ))}
    </div>
  </Container>

  <Container as="section" size="lg" class="pb-16">
    <Methodology />
  </Container>
</Base>
