---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { formatDateLong } from '../../lib/locale';
import conventionsData from '../../data/conventions.json';

const seo = {
  title: 'Conventions collectives — indemnité et préavis par IDCC',
  description:
    'Catalogue des conventions collectives couvertes : indemnité conventionnelle de licenciement et préavis par IDCC, à partir des modèles officiels du Code du travail numérique.',
  path: '/conventions-collectives',
};

const breadcrumbItems = [
  { name: 'Accueil', path: '/' },
  { name: 'Conventions collectives', path: '/conventions-collectives' },
];

const conventions = conventionsData.conventions;
const verifiedAt = conventionsData.source_verified_at;
---
<Base {seo}>
  <Container as="main" size="lg" class="py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-6 mb-8">
      <h1 class="text-4xl font-extrabold text-slate-900 sm:text-5xl">Conventions collectives</h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        L’indemnité de licenciement prévue par votre convention collective peut être plus favorable que l’indemnité légale : c’est le montant le plus élevé qui s’applique. Voici les {conventions.length} conventions couvertes par les modèles officiels du Code du travail numérique.
      </p>
      <p class="mt-2 text-sm text-slate-500">
        Liste issue de SocialGouv, vérifiée le {formatDateLong(verifiedAt)}.
      </p>
    </header>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {conventions.map((c) => (
        <div class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-3">
          <span class="shrink-0 rounded bg-indigo-50 px-2 py-1 text-xs font-semibold text-indigo-700">IDCC {c.idcc}</span>
          <span class="text-sm text-slate-800">{c.name}</span>
        </div>
      ))}
    </div>

    <section class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
      <p>
        Le calcul de l’indemnité <strong>conventionnelle</strong> par convention est en cours d’intégration à partir des modèles publicodes de SocialGouv. En attendant, calculez votre indemnité <strong>légale</strong>, qui constitue le plancher : votre convention ne peut pas verser moins.
      </p>
      <p class="mt-3">
        <a href="/calcul-indemnite-licenciement" class="font-medium text-indigo-700 hover:underline">→ Calculer mon indemnité légale de licenciement</a>
      </p>
    </section>

    <section class="mt-8 text-xs text-slate-500">
      <p>Source : <a href="https://code.travail.gouv.fr" rel="external" class="text-indigo-700 hover:underline">Code du travail numérique</a> (modèles publicodes maintenus par SocialGouv). L’IDCC est l’identifiant officiel de la convention.</p>
    </section>
  </Container>
</Base>
