---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Methodology from '../../components/Methodology.astro';
import { formatDateLong } from '../../lib/locale';
import conventionsData from '../../data/conventions.json';

export function getStaticPaths() {
  return conventionsData.conventions.map((c) => ({
    params: { slug: `${c.idcc}-${c.slug.replace(/_/g, '-')}` },
    props: { conv: c },
  }));
}

const { conv } = Astro.props;
const factors: string[] = (conv as any).factors ?? [];
const verifiedAt = conventionsData.source_verified_at;
const path = `/conventions-collectives/${conv.idcc}-${conv.slug.replace(/_/g, '-')}`;

const seo = {
  title: `Indemnité de licenciement — ${conv.name} (IDCC ${conv.idcc})`,
  description: `Indemnité de licenciement dans la convention collective ${conv.name} (IDCC ${conv.idcc}) : minimum légal, indemnité conventionnelle et calcul officiel. Source Code du travail numérique.`,
  path,
};

const breadcrumbItems = [
  { name: 'Accueil', path: '/' },
  { name: 'Conventions collectives', path: '/conventions-collectives' },
  { name: `IDCC ${conv.idcc}`, path },
];

const officialTool = 'https://code.travail.gouv.fr/outils/indemnite-licenciement';
---
<Base {seo}>
  <Container as="main" size="md" class="py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-6 mb-8">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">
        Indemnité de licenciement — {conv.name}
      </h1>
      <p class="mt-3 text-sm font-medium text-indigo-700">Convention collective IDCC {conv.idcc}</p>
      <p class="mt-4 text-lg leading-relaxed text-slate-700">
        Si vous relevez de la convention <strong>{conv.name}</strong>, votre indemnité de licenciement est le montant le plus favorable entre l’indemnité <strong>légale</strong> et l’indemnité <strong>conventionnelle</strong> prévue par cette convention.
      </p>
      <p class="mt-2 text-sm text-slate-500">Données SocialGouv vérifiées le {formatDateLong(verifiedAt)}.</p>
    </header>

    <section class="space-y-3 text-slate-700">
      <h2 class="text-xl font-bold text-slate-900">Le plancher : l’indemnité légale</h2>
      <p>
        Quelle que soit votre convention, vous ne pouvez pas recevoir moins que l’indemnité légale (un quart de mois de salaire par année jusqu’à 10 ans, un tiers au-delà, à partir de 8 mois d’ancienneté).
      </p>
      <p>
        <a href="/calcul-indemnite-licenciement" class="font-medium text-indigo-700 hover:underline">→ Calculer mon indemnité légale</a>
      </p>
    </section>

    {factors.length > 0 && (
      <section class="mt-10 space-y-3 text-slate-700">
        <h2 class="text-xl font-bold text-slate-900">Ce qui entre dans le calcul conventionnel</h2>
        <p>
          Dans la convention {conv.name}, l’indemnité conventionnelle de licenciement dépend des éléments suivants :
        </p>
        <ul class="flex flex-wrap gap-2">
          {factors.map((f) => (
            <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700">{f}</li>
          ))}
        </ul>
        <p class="text-sm text-slate-500">Éléments issus du modèle officiel du Code du travail numérique pour cette convention.</p>
      </section>
    )}

    <section class="mt-10 rounded-xl border border-indigo-200 bg-indigo-50 p-5">
      <h2 class="text-lg font-bold text-slate-900">Montant conventionnel exact</h2>
      <p class="mt-2 text-sm text-slate-700">
        Le calcul conventionnel suit des règles propres à chaque convention (catégorie, motif, majorations). Pour le montant exact applicable à la convention IDCC {conv.idcc}, utilisez le calculateur officiel, qui intègre ces règles :
      </p>
      <p class="mt-3">
        <a href={officialTool} rel="external" class="inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700">
          Calculateur officiel — code.travail.gouv.fr →
        </a>
      </p>
    </section>

    <section class="mt-10">
      <Methodology />
    </section>

    <p class="mt-8 text-sm">
      <a href="/conventions-collectives" class="text-indigo-700 hover:underline">← Toutes les conventions collectives</a>
    </p>
  </Container>
</Base>
