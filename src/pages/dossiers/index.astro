---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const seo = {
  title: 'Dossiers pratiques — licenciement, rupture, prud’hommes',
  description:
    'Dossiers pratiques sur le licenciement, la rupture conventionnelle, le préavis, le solde de tout compte et les conventions collectives. Premiers dossiers en cours de publication.',
  path: '/dossiers',
};

const breadcrumbItems = [
  { name: 'Accueil', path: '/' },
  { name: 'Dossiers', path: '/dossiers' },
];

const aVenir = [
  'Indemnité de licenciement : salaire de référence, mode d’emploi',
  'Barème Macron année par année : plancher et plafond détaillés',
  'Rupture conventionnelle et chômage après le 1ᵉʳ septembre 2026',
  'Préavis de licenciement : durées selon l’ancienneté',
  'Solde de tout compte : ce qui doit y figurer',
];
---
<Base {seo}>
  <Container as="main" size="lg" class="py-8 sm:py-12">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-6 mb-8">
      <h1 class="text-4xl font-extrabold text-slate-900 sm:text-5xl">Dossiers pratiques</h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        Des dossiers sourcés sur le licenciement et la fin du contrat de travail. Les premiers titres sont en cours de publication.
      </p>
    </header>

    <ul class="space-y-3">
      {aVenir.map((t) => (
        <li class="flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-4 text-slate-700">
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-500">Bientôt</span>
          <span>{t}</span>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-sm text-slate-600">
      En attendant, lancez le <a href="/calcul-indemnite-licenciement" class="text-indigo-700 hover:underline">calcul de votre indemnité de licenciement</a>.
    </p>
  </Container>
</Base>
